# ── PISTE OAuth 2.0 ────────────────────────────────────────────────────────────
PISTE_CLIENT_ID=your_piste_client_id_here
PISTE_CLIENT_SECRET=your_piste_client_secret_here
PISTE_OAUTH_URL=https://piste.gouv.fr/api/oauth/token
TOKEN_CACHE_TTL=3600

# ── Groq ───────────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ── PostgreSQL (jurisprudence locale) ─────────────────────────────────────────
# Format : postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://eloquence:your_db_password_here@localhost:5432/eloquence_db
DB_PASSWORD=your_db_password_here

# ── Judilibre dump (optionnel) ─────────────────────────────────────────────────
# Laissez vide pour découverte automatique via data.gouv.fr
# Ou spécifiez une URL directe pour forcer un dump particulier
JUDILIBRE_DUMP_URL=
