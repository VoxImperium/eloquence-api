# ── Groq ────────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ── OpenLegi (jurisprudence + textes de loi) ────────────────────────────────
# Obtenez votre token sur https://auth.openlegi.fr/users/dashboard/?tab=cles-api
OPENLEGI_TOKEN=your_openlegi_token_here

# ── LEGAL-BERT EU (Zéro coûts, ~420MB RAM avec FP32) ────────────────────────
# Modèle LEGAL-BERT vérifié avec couverture EU (nlpaueb/legal-bert-base-uncased)
# ~420MB (FP32) — compatible Railway Free tier (512MB)
LEGALBERT_MODEL=nlpaueb/legal-bert-base-uncased
