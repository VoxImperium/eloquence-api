# ── Groq ────────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ── OpenLegi (jurisprudence + textes de loi) ────────────────────────────────
# Obtenez votre token sur https://auth.openlegi.fr/users/dashboard/?tab=cles-api
OPENLEGI_TOKEN=your_openlegi_token_here

# ── LEGAL-BERT EU (Zéro coûts, ~150MB RAM avec INT8) ────────────────────────
# LEGAL-BERT EU : Zéro coûts, ~150MB RAM avec INT8
# Modèle par défaut : EU legislation 100k
LEGALBERT_MODEL=minixxie/legal-bert-eur-lex-base-uncased
