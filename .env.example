# ── Groq ───────────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ── PostgreSQL (jurisprudence locale) ─────────────────────────────────────────
# Format : postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://eloquence:your_db_password_here@localhost:5432/eloquence_db
DB_PASSWORD=your_db_password_here

# ── Judilibre dump (optionnel) ─────────────────────────────────────────────────
# Laissez vide pour découverte automatique via data.gouv.fr
# Ou spécifiez une URL directe pour forcer un dump particulier
JUDILIBRE_DUMP_URL=
